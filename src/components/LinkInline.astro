---
interface Props {
  href: string
  ariaLabel?: string
}

const { href, ariaLabel } = Astro.props
---

<a href={href} role="link" class="inline-flex items-center text-lg font-medium text-yellow-500 dark:text-yellow-200 dark:hover:text-yellow-300 hover:text-yellow-700" aria-label={ariaLabel}>
  <slot />
</a>
