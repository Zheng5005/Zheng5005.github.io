---
const LANGUAGES = [
  { code: "en", label: "EN" },
  { code: "es", label: "ES" },
  { code: "it", label: "IT" },
]
---

<div class="relative ml-1 mr-1">
  <button
    id="lang-toggle-btn"
    class="appearance-none border-none flex items-center gap-1 hover:scale-110 transition text-sm font-medium px-1"
    aria-label="Change language"
  >
    <svg xmlns="http://www.w3.org/2000/svg" class="size-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="12" cy="12" r="10"></circle>
      <path d="M2 12h20"></path>
      <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path>
    </svg>
    <span id="current-lang-label">EN</span>
  </button>
  <div
    id="lang-menu"
    class="absolute hidden scale-80 top-8 right-0 text-sm p-1 min-w-[5rem] rounded-md border border-gray-100 bg-white/90 dark:bg-gray-900/90 dark:border-gray-500/20 shadow-[0_3px_10px_rgb(0,0,0,0.2)] backdrop-blur-md"
  >
    <ul>
      {
        LANGUAGES.map(({ code, label }) => (
          <li
            class="lang-menu-option px-2 py-1.5 cursor-default hover:bg-neutral-400/40 dark:hover:bg-gray-500/50 rounded-sm"
            data-lang={code}
          >
            {label}
          </li>
        ))
      }
    </ul>
  </div>
</div>

<style>
  #lang-menu.open {
    display: inline;
    animation: scale-up-lang 0.15s cubic-bezier(0.25, 0.46, 0.45, 0.94) both;
  }

  @keyframes scale-up-lang {
    from {
      transform: scale(0.8);
      opacity: 0;
    }
    to {
      transform: scale(1);
      opacity: 1;
    }
  }
</style>

<script>
  import i18next from "../i18n/config"

  function updatePageTranslations() {
    document.querySelectorAll("[data-i18n]").forEach((el) => {
      const key = el.getAttribute("data-i18n")!
      const translated = i18next.t(key)
      if (el.hasAttribute("data-i18n-html")) {
        el.innerHTML = translated
      } else {
        el.textContent = translated
      }
    })

    document.querySelectorAll("[data-i18n-title]").forEach((el) => {
      const key = el.getAttribute("data-i18n-title")!
      ;(el as HTMLElement).title = i18next.t(key)
    })

    const label = document.getElementById("current-lang-label")
    if (label) {
      label.textContent = i18next.language.toUpperCase()
    }

    document.documentElement.lang = i18next.language
  }

  function setupLanguageSwitcher() {
    const langMenu = document.getElementById("lang-menu")
    const langBtn = document.getElementById("lang-toggle-btn")

    if (!langMenu || !langBtn) return

    document.addEventListener("click", () => langMenu.classList.remove("open"))

    langBtn.addEventListener("click", (e) => {
      e.stopPropagation()
      const isClosed = !langMenu.classList.contains("open")
      langMenu.classList[isClosed ? "add" : "remove"]("open")
    })

    document.querySelectorAll(".lang-menu-option").forEach((el) => {
      el.addEventListener("click", (e) => {
        const lang = (e.currentTarget as HTMLElement).dataset.lang!
        localStorage.setItem("language", lang)
        i18next.changeLanguage(lang).then(() => {
          updatePageTranslations()
        })
      })
    })
  }

  // Run on initial load
  updatePageTranslations()
  setupLanguageSwitcher()

  // Re-run after Astro page transitions
  document.addEventListener("astro:after-swap", () => {
    updatePageTranslations()
    setupLanguageSwitcher()
  })
</script>
